---
import { Picture } from "astro:assets";
import Date from "./Date.astro";

const { post, aboveFold = false } = Astro.props;
const { title, pubDate, summary, coverImage, coverAlt } = post.data;
---

<article>
  <a href={`/article/${post.slug}/`}>
    {
      aboveFold ? (
        <Picture
          src={coverImage}
          alt={coverAlt}
          loading={"eager"}
          fetchpriority={"high"}
          decoding={"sync"}
          class="rounded-sm aspect-video shadow"
        />
      ) : (
        <Picture
          src={coverImage}
          alt={coverAlt}
          class="rounded-sm aspect-video shadow"
        />
      )
    }
  </a>

  <Date date={pubDate} class="mt-2 mb-1" />

  <h2>
    <a href={`/article/${post.slug}/`} class="text-xl lg:text-2xl font-bold"
      >{title}</a
    >
  </h2>

  <div class="mt-3 lg:text-lg font-manjari">
    {summary}
  </div>
</article>
