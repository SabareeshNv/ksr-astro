---
import Date from "./Date.astro";
import { Image } from "astro:assets";

const { title, malayalamTitle, pubDate, coverImage, coverAlt } = Astro.props;
---

<section>
  <div class="wrapper">
    <div class="mt-8">
      <Date date={pubDate} class="text-lg lg:text-xl mb-2" />
      <h1 class="text-3xl lg:text-4xl xl:text-5xl font-bold mb-1">
        {title}
      </h1>
      <span class="font-manjari text-2xl lg:text-3xl block mb-4"
        >{malayalamTitle}</span
      >
    </div>
  </div>
  <Image
    src={coverImage}
    alt={coverAlt}
    loading={"eager"}
    fetchpriority={"high"}
    decoding={"sync"}
    quality={"max"}
    class="bg-[#374151] w-full max-h-[600px]"
  />
</section>
